\section{Courses}\label{sec:res-courses}

\begin{enumerate}
	\item \textbf{Knowledge Graphs (Krötzsch), TU Dresden.} Full lecture series with videos.\\
	      \url{https://iccl.inf.tu-dresden.de/web/Knowledge_Graphs/en}
	\item \textbf{CS224W: Machine Learning with Graphs, Stanford.} Comprehensive ML + graphs.\\
	      \url{https://web.stanford.edu/class/cs224w/}
	\item \textbf{Graph Data Modeling (Neo4j Graph Academy).} Free, self-paced.\\
	      \url{https://graphacademy.neo4j.com/courses/modeling-fundamentals/}
	\item \textbf{Agentic Knowledge Graph Construction (DeepLearning.AI).} LLM-based KG building.\\
	      \url{https://www.deeplearning.ai/courses/agentic-knowledge-graph-construction/}
	\item \textbf{Knowledge Graphs for AI Agent API Discovery (DeepLearning.AI).} KG for agents.\\
	      \url{https://learn.deeplearning.ai/courses/knowledge-graphs-for-ai-agent-api-discovery/}
	\item \textbf{KDD 2026 KG Tutorial (Whang et al.).} Embeddings and GraphRAG.\\
	      \url{https://bdi-lab.github.io/kkg_kdd2026/}
	\item \textbf{SPARQL by Example (Cambridge Semantics).} Free interactive tutorial.\\
	      \url{https://www.cambridgesemantics.com/blog/semantic-university/learn-sparql/}
\end{enumerate}


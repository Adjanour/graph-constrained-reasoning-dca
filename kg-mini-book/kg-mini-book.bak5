\chapter{Appendix: Mathematical Notation}\label{app:notation}

\begin{longtable}{lp{5cm}p{5cm}}
	\caption{Summary of mathematical notation}
	\label{tab:notation}                                                                                         \\
	\toprule
	Symbol                       & Meaning                                           & First used                \\
	\midrule
	\endfirsthead
	\caption[]{Summary of mathematical notation (continued)}                                                     \\
	\toprule
	Symbol                       & Meaning                                           & First used                \\
	\midrule
	\endhead
	\bottomrule
	\endfoot
	$G = (V, E)$                 & Graph with vertices $V$ and edges $E$             & \S\ref{sec:basic-defs}    \\
	$\kg = (\cE, \cR, T)$        & Knowledge graph with entities, relations, triples & \S\ref{sec:kg-def}        \\
	$A \in \{0,1\}^{n \times n}$ & Adjacency matrix                                  & \S\ref{sec:graph-repr}    \\
	$L = D - A$                  & Graph Laplacian                                   & \S\ref{sec:spectral}      \\
	$\R^d$                       & $d$-dimensional real vector space                 & \S\ref{sec:emb-problem}   \\
	$\C^d$                       & $d$-dimensional complex vector space              & \S\ref{sec:translational} \\
	$\bone$                      & All-ones vector                                   & \S\ref{sec:spectral}      \\
	$\| \cdot \|_p$              & $L_p$ norm                                        & \S\ref{sec:translational} \\
	$\circ$                      & Hadamard (element-wise) product                   & \S\ref{sec:translational} \\
\end{longtable}


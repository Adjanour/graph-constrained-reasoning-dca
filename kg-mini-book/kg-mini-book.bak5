% Chapter 11: Storage and Production Infrastructure
% =============================================================================
\chapter{Storage and Production Infrastructure}\label{ch:storage}

\paragraph{Overview.}
Behind every production KG is a graph database system that handles storage, indexing, querying, and scaling. This chapter surveys the major graph databases, their trade-offs, scaling strategies, and guidance on when (and when not) to use a graph database.

% ---------------------------------------------------------------------------
\section{Graph Databases}\label{sec:graph-dbs}

\begin{longtable}{lp{3cm}p{3.5cm}p{4cm}}
	\caption{Major graph databases}
	\label{tab:graph-dbs}                                                      \\
	\toprule
	Database       & Model        & Query language  & Best for                 \\
	\midrule
	\endfirsthead
	\caption[]{Major graph databases (continued)}                              \\
	\toprule
	Database       & Model        & Query language  & Best for                 \\
	\midrule
	\endhead
	\bottomrule
	\endfoot
	Neo4j          & LPG          & Cypher, GQL     & OLTP, most popular, ACID \\
	Amazon Neptune & LPG + RDF    & Gremlin, SPARQL & AWS-native, multi-model  \\
	TigerGraph     & LPG          & GSQL            & Large-scale analytics    \\
	ArangoDB       & Multi-model  & AQL             & Mixed graph + document   \\
	Virtuoso       & RDF          & SPARQL          & Large RDF stores         \\
	Stardog        & RDF          & SPARQL, OWL     & Enterprise reasoning     \\
	GraphDB        & RDF          & SPARQL, SHACL   & Semantic web             \\
	Jena Fuseki    & RDF          & SPARQL          & Lightweight research     \\
	Dgraph         & LPG (custom) & DQL             & Distributed, low latency \\
\end{longtable}

% ---------------------------------------------------------------------------
\section{Storage Internals}\label{sec:storage-internals}

\subsection{Native Graph Storage}

Neo4j uses \emph{index-free adjacency}: each node stores direct pointers (file offsets) to its relationships. Traversing from one node to its neighbour requires no index lookup --- just a pointer dereference.

$$O(1) \text{ per edge traversal}$$

This is why native graph DBs outperform relational DBs on multi-hop queries by orders of magnitude.

\subsection{Indexing Strategies}

\begin{description}
	\item[Token indices:] Fast lookup of nodes by label/type.
	\item[Property indices:] B-tree or hash index on frequently-queried properties.
	\item[Composite indices:] Multi-property index for combined filters.
	\item[Full-text search:] Lucene-based (Neo4j) for text properties.
	\item[Spatial indices:] Geospatial queries on location data.
\end{description}

% ---------------------------------------------------------------------------
\section{Scaling}\label{sec:scaling}

\subsection{Partitioning}

Sharding a graph is fundamentally harder than sharding relational tables because edges cross machine boundaries.

\begin{definition}[Edge-cut partitioning]
	Assign vertices to machines $M_1, \dots, M_p$. Edges whose endpoints are on different machines become \emph{cross-partition}, requiring remote calls during traversal.
\end{definition}

\begin{definition}[Vertex-cut partitioning]
	Assign each edge to a machine, replicating vertices across partitions. Reduces cross-partition traversal at the cost of increased storage.
\end{definition}

\textbf{Tools:} METIS, ParMETIS, and PowerGraph (vertex-cut) for partitioning large graphs.

\subsection{Distributed Graph Databases}

\begin{description}
	\item[Amazon Neptune:] Managed, clustered (up to 128 TB), read replicas, multi-AZ.
	\item[TigerGraph:] MPP (massively parallel processing), up to hundreds of nodes, automatic sharding.
	\item[JanusGraph:] Open-source, uses HBase/Cassandra for storage, Elasticsearch for indexing.
	\item[Dgraph:] Distributed by design, uses Raft consensus, low-latency.
\end{description}

% ---------------------------------------------------------------------------
\section{Caching Strategies}\label{sec:caching}

\begin{description}
	\item[Neighbourhood cache:] Pre-fetch 2-hop neighbourhoods for frequently queried entities.
	\item[Pattern cache:] Cache results of common query templates (e.g., ``top-10 movies by genre'' with parameterised genre).
	\item[Embedding cache:] Cache precomputed entity embeddings for ML workloads, updating on a TTL schedule.
	\item[Result cache:] Short-lived cache for identical query strings.
\end{description}

% ---------------------------------------------------------------------------
\section{When Not to Use a Graph Database}\label{sec:no-graph}

Graph databases are not a panacea. Avoid them when:

\begin{enumerate}
	\item \textbf{Pure aggregation:} SUM, COUNT, GROUP BY are faster in columnar/relational stores.
	\item \textbf{Trivial relationships:} Flat data with a single join type (e.g., key-value with a secondary index).
	\item \textbf{Full-text search:} Elasticsearch or vector DB for semantic search over text.
	\item \textbf{High-volume simple lookups:} Key-value stores (Redis, DynamoDB) for single-key lookups.
	\item \textbf{Analytics-only:} Data warehouse (Snowflake, Redshift) for analytical queries over billions of rows.
\end{enumerate}

The sweet spot for graph databases is \emph{multi-hop traversal over richly connected data} --- exactly the KGQA use case.

% ---------------------------------------------------------------------------
\section{Exercises}

\begin{exercise}
	Compare the storage representation of a 3-hop path $(e_0, r_1, e_1, r_2, e_2, r_3, e_3)$ in a relational database (triples table) vs.\ a native graph database (pointer-based). Estimate the I/O cost for each.
\end{exercise}

\begin{exercise}
	Explain why edge-cut partitioning is NP-hard. How do METIS and ParMETIS approximate the optimal partition?
\end{exercise}

\begin{exercise}
	Given a KG with 100M entities and 1B triples, estimate the storage requirements for Neo4j (native) vs.\ a relational triple store. What factors dominate the storage cost?
\end{exercise}

% =============================================================================
% Chapter 12: Advanced Topics
% =============================================================================
\chapter{Advanced Topics}\label{ch:advanced}

\paragraph{Overview.}
This chapter surveys frontier research topics in knowledge graphs: temporal and hyper-relational KGs, inductive reasoning, neuro-symbolic AI, and quality assurance.

% ---------------------------------------------------------------------------
\section{Temporal Knowledge Graphs}\label{sec:temporal}

\begin{definition}[Temporal triple]
	A \emph{temporal triple} extends a standard triple with a time interval:
	$$(h, r, t, [\tau_{\text{start}}, \tau_{\text{end}}])$$
	where $\tau_{\text{start}}$ and $\tau_{\text{end}}$ are timestamps indicating when the fact was valid.
\end{definition}

\begin{example}
	$$(\text{Elvis\_Presley}, \text{married\_to}, \text{Priscilla\_Presley}, [1967, 1973])$$
	$$(\text{Elvis\_Presley}, \text{married\_to}, \text{Priscilla\_Presley}, [1967, \infty)) \text{ is INFERRED false}$$
\end{example}

\subsection{Temporal KG Embeddings}

\begin{description}
	\item[TComplEx (Lacroix et al., 2020):] Extends Compl\'{e}x with time-aware scoring. Each timestamp has an embedding that modulates entity representations.
	\item[TeRo (Xu et al., 2020):] Relations as time-aware rotations in complex space.
	\item[T-GAP (Jung et al., 2021):] Temporal graph attention network for event forecasting.
	\item[ChronoR:] Rotations in quaternion space, capturing both temporal and relational structure.
\end{description}

\subsection{Key Tasks}

\begin{enumerate}
	\item \textbf{Temporal link prediction:} Predict $(h, r, ?, \tau)$ given known facts up to time $\tau$.
	\item \textbf{Event forecasting:} Predict what facts will become true at future time $\tau > \tau_{\max}$.
	\item \textbf{Temporal reasoning:} Answer queries involving temporal constraints (``Which award did Elvis win after 1970?'').
\end{enumerate}

% ---------------------------------------------------------------------------
\section{Hyper-Relational Knowledge Graphs}\label{sec:hyper-rel}

Wikidata uses \emph{qualifiers} --- additional key-value pairs that contextualise a statement:

\begin{example}[Wikidata qualifier pattern]
	\begin{lstlisting}[language=XML,numbers=none]
wd:Elvis_Presley  wdt:award_received  wd:Grammy_Award .
                  pq:point_in_time    "1975"^^xsd:year ;
                  pq:category         "Best Pop Vocal" .
\end{lstlisting}
\end{example}

Standard models treat this as a set of independent triples, losing the connection between the award and its category/year. Hyper-relational models preserve this structure.

\begin{description}
	\item[StarE (Galkin et al., 2020):] Encodes the primary triple and all qualifiers jointly using an attention mechanism.
	\item[QUAD (Tran et al., 2023):] Treats each hyper-relational fact as a 4th-order tensor.
	\item[HINGE:] Inductive hyper-relational reasoning with GNNs.
\end{description}

% ---------------------------------------------------------------------------
\section{Inductive KG Reasoning}\label{sec:inductive}

Inductive methods generalise to entities unseen during training. This is critical for production: KGs grow continuously, and retraining from scratch is impractical.

\begin{table}[h]
	\centering
	\caption{Inductive KG reasoning methods}
	\label{tab:inductive}
	\begin{tabular}{lp{5cm}p{5cm}}
		\toprule
		Method                      & Approach                          & Inductive on                \\
		\midrule
		GraIL (Teru et al., 2020)   & Subgraph GNN for rule extraction  & Entities                    \\
		NBFNet (Zhu et al., 2021)   & Label propagation GNN             & Entities                    \\
		ULTRA (Galkin et al., 2024) & Pre-trained on relation structure & Both entities and relations \\
		KG-ICL (Zhu et al., 2025)   & In-context learning over KG       & Full graph                  \\
		\bottomrule
	\end{tabular}
\end{table}

\begin{definition}[ULTRA (Galkin et al., 2024)]
	ULTRA pre-trains a model on diverse KGs. At inference, given a \emph{new} KG:
	\begin{enumerate}
		\item Construct a relation graph $G_{\cR}$ where nodes are relations and edges indicate relation co-occurrence.
		\item Run a GNN on $G_{\cR}$ to compute relation representations.
		\item Use these representations as the message functions for NBFNet on the target KG.
	\end{enumerate}
	Key insight: relation graph structure generalises across KGs even when entities and relations are entirely different.
\end{definition}

% ---------------------------------------------------------------------------
\section{Neuro-Symbolic AI}\label{sec:neuro-symbolic}

The convergence of neural learning and symbolic reasoning:

\begin{description}
	\item[Differentiable rule learning:] Learn logical rules via continuous optimisation (NeuralLP, DRUM). Extract symbolic rules after training.
	\item[Constraint-guided learning:] Use KG ontology constraints (type, range) to guide or prune neural predictions (DCA-Trie philosophy).
	\item[Abductive reasoning:] Given observations $O$ and a KG $\kg$, infer the best explanation $E$ such that $\kg \cup E \models O$.
	\item[Probabilistic soft logic (PSL):] Combine first-order logic rules with probabilistic weights, learned from data.
\end{description}

\begin{example}[DCA-Trie as neuro-symbolic system]
	DCA-Trie bridges neural and symbolic in two ways:
	\begin{enumerate}
		\item \textbf{Symbolic:} KG ontology provides type/range constraints as symbolic rules.
		\item \textbf{Neural:} LLM scores remaining paths to select the answer.
	\end{enumerate}
	The symbolic oracle prunes the search space; the neural model selects among survivors.
\end{example}

% ---------------------------------------------------------------------------
\section{Quality Assurance}\label{sec:qa-advanced}

\begin{description}
	\item[Completeness estimation:] How much of the real-world knowledge is captured? Use rule mining (AMIE) to find patterns; if a rule predicts many missing triples, the KG is likely incomplete in that area.
	\item[Error detection:] Learn a scoring model; triples with anomalously low scores are candidates for manual review.
	\item[Freshness tracking:] Monitor entity update frequency; stale entities (no updates in >$T$ days) may need refreshing.
	\item[Fairness auditing:] Check for representation bias: are certain demographic groups over- or under-represented in the KG?
\end{description}

% ---------------------------------------------------------------------------
\section{Exercises}

\begin{exercise}
	Explain why temporal KG embeddings require additional parameters compared to static embeddings. Estimate the parameter increase for TComplEx vs.\ Compl\'{e}x with $|\cT|$ timestamps.
\end{exercise}

\begin{exercise}
	Implement a simple inductive link predictor using GraIL's subgraph extraction: given $(h, r, t) \in \kg_{\text{train}}$, extract the $k$-hop enclosing subgraph and run a GNN to classify whether $(h, r, t)$ holds.
\end{exercise}

\begin{exercise}
	Discuss the trade-offs between materialised reasoning (forward chaining) and query-time reasoning (backward chaining) for a KG with 1B triples and frequent updates.
\end{exercise}

